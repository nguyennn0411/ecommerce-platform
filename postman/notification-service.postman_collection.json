{
  "info": {
    "_postman_id": "92de07d4-0f57-4b34-80e6-d88cd7a578b0",
    "name": "Ecommerce - Notification Service",
    "description": "Local API checks for Notification Service and MailHog.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8086" },
    { "key": "recipient", "value": "postman-test@ecommerce.test" },
    { "key": "userId", "value": "11111111-1111-1111-1111-111111111111" },
    { "key": "orderId", "value": "22222222-2222-2222-2222-222222222222" },
    { "key": "notificationId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Ping",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/notifications/ping"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status is 200', () => pm.response.to.have.status(200));",
          "pm.test('Service is UP', () => pm.expect(pm.response.json().status).to.eql('UP'));"
        ] }
      }]
    },
    {
      "name": "2. Mail configuration",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/notifications/mail/config"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status is 200', () => pm.response.to.have.status(200));",
          "pm.test('Mail is configured', () => pm.expect(pm.response.json().data.configured).to.eql(true));"
        ] }
      }]
    },
    {
      "name": "3. Send email",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"orderId\": \"{{orderId}}\",\n  \"recipient\": \"{{recipient}}\",\n  \"subject\": \"Postman test - Notification Service\",\n  \"content\": \"<h1>Notification Service OK</h1><p>Email generated by Postman.</p>\",\n  \"html\": true\n}"
        },
        "url": "{{baseUrl}}/api/notifications/email"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status is 200', () => pm.response.to.have.status(200));",
          "const json = pm.response.json();",
          "pm.test('Notification is SENT', () => pm.expect(json.data.status).to.eql('SENT'));",
          "pm.collectionVariables.set('notificationId', json.data.notificationId);"
        ] }
      }]
    },
    {
      "name": "4. Get notification by ID",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/notifications/{{notificationId}}"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status is 200', () => pm.response.to.have.status(200));",
          "pm.test('ID matches', () => pm.expect(pm.response.json().data.notificationId).to.eql(pm.collectionVariables.get('notificationId')));"
        ] }
      }]
    },
    {
      "name": "5. Get notifications by recipient",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/notifications?recipient={{recipient}}&limit=10"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status is 200', () => pm.response.to.have.status(200));",
          "pm.test('Returns at least one item', () => pm.expect(pm.response.json().data.length).to.be.above(0));"
        ] }
      }]
    },
    {
      "name": "6. Get notifications by order",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/notifications/orders/{{orderId}}"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status is 200', () => pm.response.to.have.status(200));",
          "pm.test('Returns at least one item', () => pm.expect(pm.response.json().data.length).to.be.above(0));"
        ] }
      }]
    },
    {
      "name": "7. Reject invalid email payload",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"recipient\": \"not-an-email\",\n  \"subject\": \"\",\n  \"content\": \"\",\n  \"html\": false\n}"
        },
        "url": "{{baseUrl}}/api/notifications/email"
      },
      "event": [{
        "listen": "test",
        "script": { "exec": [
          "pm.test('Status is 400', () => pm.response.to.have.status(400));",
          "pm.test('Response indicates failure', () => pm.expect(pm.response.json().success).to.eql(false));"
        ] }
      }]
    }
  ]
}
